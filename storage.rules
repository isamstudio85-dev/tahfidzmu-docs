rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Foto profil (admin, musyrif, pengawas, santri) ───
    // Maksimal 5MB, hanya gambar
    match /{folder}_photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── Logo pesantren ───
    match /pesantren_logos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── Default: tolak semua yang tidak cocok ───
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
