    "ayahs":  [
                  {
                      "numberInSurah":  1,
                      "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
                      "translation":  "Tahukah kamu (orang) yang mendustakan agama?"
                  },
                  {
                      "numberInSurah":  2,
                      "arabic":  "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
                      "translation":  "Itulah orang yang menghardik anak yatim,"
                  },
                  {
                      "numberInSurah":  3,
                      "arabic":  "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
                      "translation":  "dan tidak menganjurkan memberi makan orang miskin."
                  },
                  {
                      "numberInSurah":  4,
                      "arabic":  "فَوَيْلٌۭ لِّلْمُصَلِّينَ",
                      "translation":  "Maka kecelakaanlah bagi orang-orang yang shalat,"
                  },
                  {
                      "numberInSurah":  5,
                      "arabic":  "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
                      "translation":  "(yaitu) orang-orang yang lalai dari shalatnya,"
                  },
                  {
                      "numberInSurah":  6,
                      "arabic":  "ٱلَّذِينَ هُمْ يُرَآءُونَ",
                      "translation":  "orang-orang yang berbuat riya,"
                  },
                  {
                      "numberInSurah":  7,
                      "arabic":  "وَيَمْنَعُونَ ٱلْمَاعُونَ",
                      "translation":  "dan enggan (menolong dengan) barang berguna."
                  }
              ]
