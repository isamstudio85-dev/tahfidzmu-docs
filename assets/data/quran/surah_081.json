{
    "number":  81,
    "name":  "سُورَةُ التَّكۡوِيرِ",
    "englishName":  "At-Takwir",
    "numberOfAyahs":  29,
    "revelationType":  "Meccan",
    "ayahs":  [
                  {
                      "numberInSurah":  1,
                      "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلشَّمْسُ كُوِّرَتْ",
                      "translation":  "Apabila matahari digulung,"
                  },
                  {
                      "numberInSurah":  2,
                      "arabic":  "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ",
                      "translation":  "dan apabila bintang-bintang berjatuhan,"
                  },
                  {
                      "numberInSurah":  3,
                      "arabic":  "وَإِذَا ٱلْجِبَالُ سُيِّرَتْ",
                      "translation":  "dan apabila gunung-gunung dihancurkan,"
                  },
                  {
                      "numberInSurah":  4,
                      "arabic":  "وَإِذَا ٱلْعِشَارُ عُطِّلَتْ",
                      "translation":  "dan apabila unta-unta yang bunting ditinggalkan (tidak diperdulikan)"
                  },
                  {
                      "numberInSurah":  5,
                      "arabic":  "وَإِذَا ٱلْوُحُوشُ حُشِرَتْ",
                      "translation":  "dan apabila binatang-binatang liar dikumpulkan,"
                  },
                  {
                      "numberInSurah":  6,
                      "arabic":  "وَإِذَا ٱلْبِحَارُ سُجِّرَتْ",
                      "translation":  "dan apabila lautan dijadikan meluap"
                  },
                  {
                      "numberInSurah":  7,
                      "arabic":  "وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ",
                      "translation":  "dan apabila ruh-ruh dipertemukan (dengan tubuh)"
                  },
                  {
                      "numberInSurah":  8,
                      "arabic":  "وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ",
                      "translation":  "dan apabila bayi-bayi perempuan yang dikubur hidup-hidup ditanya,"
                  },
                  {
                      "numberInSurah":  9,
                      "arabic":  "بِأَىِّ ذَنۢبٍۢ قُتِلَتْ",
                      "translation":  "karena dosa apakah dia dibunuh,"
                  },
                  {
                      "numberInSurah":  10,
                      "arabic":  "وَإِذَا ٱلصُّحُفُ نُشِرَتْ",
                      "translation":  "dan apabila catatan-catatan (amal perbuatan manusia) dibuka,"
                  },
                  {
                      "numberInSurah":  11,
                      "arabic":  "وَإِذَا ٱلسَّمَآءُ كُشِطَتْ",
                      "translation":  "dan apabila langit dilenyapkan,"
                  },
                  {
                      "numberInSurah":  12,
                      "arabic":  "وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ",
                      "translation":  "dan apabila neraka Jahim dinyalakan,"
                  },
                  {
                      "numberInSurah":  13,
                      "arabic":  "وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ",
                      "translation":  "dan apabila surga didekatkan,"
                  },
                  {
                      "numberInSurah":  14,
                      "arabic":  "عَلِمَتْ نَفْسٌۭ مَّآ أَحْضَرَتْ",
                      "translation":  "maka tiap-tiap jiwa akan mengetahui apa yang telah dikerjakannya."
                  },
                  {
                      "numberInSurah":  15,
                      "arabic":  "فَلَآ أُقْسِمُ بِٱلْخُنَّسِ",
                      "translation":  "Sungguh, Aku bersumpah dengan bintang-bintang,"
                  },
                  {
                      "numberInSurah":  16,
                      "arabic":  "ٱلْجَوَارِ ٱلْكُنَّسِ",
                      "translation":  "yang beredar dan terbenam,"
                  },
                  {
                      "numberInSurah":  17,
                      "arabic":  "وَٱلَّيْلِ إِذَا عَسْعَسَ",
                      "translation":  "demi malam apabila telah hampir meninggalkan gelapnya,"
                  },
                  {
                      "numberInSurah":  18,
                      "arabic":  "وَٱلصُّبْحِ إِذَا تَنَفَّسَ",
                      "translation":  "dan demi subuh apabila fajarnya mulai menyingsing,"
                  },
                  {
                      "numberInSurah":  19,
                      "arabic":  "إِنَّهُۥ لَقَوْلُ رَسُولٍۢ كَرِيمٍۢ",
                      "translation":  "sesungguhnya Al Quran itu benar-benar firman (Allah yang dibawa oleh) utusan yang mulia (Jibril),"
                  },
                  {
                      "numberInSurah":  20,
                      "arabic":  "ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍۢ",
                      "translation":  "yang mempunyai kekuatan, yang mempunyai kedudukan tinggi di sisi Allah yang mempunyai \u0027Arsy,"
                  },
                  {
                      "numberInSurah":  21,
                      "arabic":  "مُّطَاعٍۢ ثَمَّ أَمِينٍۢ",
                      "translation":  "yang ditaati di sana (di alam malaikat) lagi dipercaya."
                  },
                  {
                      "numberInSurah":  22,
                      "arabic":  "وَمَا صَاحِبُكُم بِمَجْنُونٍۢ",
                      "translation":  "Dan temanmu (Muhammad) itu bukanlah sekali-kali orang yang gila."
                  },
                  {
                      "numberInSurah":  23,
                      "arabic":  "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ",
                      "translation":  "Dan sesungguhnya Muhammad itu melihat Jibril di ufuk yang terang."
                  },
                  {
                      "numberInSurah":  24,
                      "arabic":  "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍۢ",
                      "translation":  "Dan dia (Muhammad) bukanlah orang yang bakhil untuk menerangkan yang ghaib."
                  },
                  {
                      "numberInSurah":  25,
                      "arabic":  "وَمَا هُوَ بِقَوْلِ شَيْطَٰنٍۢ رَّجِيمٍۢ",
                      "translation":  "Dan Al Quran itu bukanlah perkataan syaitan yang terkutuk,"
                  },
                  {
                      "numberInSurah":  26,
                      "arabic":  "فَأَيْنَ تَذْهَبُونَ",
                      "translation":  "maka ke manakah kamu akan pergi?"
                  },
                  {
                      "numberInSurah":  27,
                      "arabic":  "إِنْ هُوَ إِلَّا ذِكْرٌۭ لِّلْعَٰلَمِينَ",
                      "translation":  "Al Quran itu tiada lain hanyalah peringatan bagi semesta alam,"
                  },
                  {
                      "numberInSurah":  28,
                      "arabic":  "لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ",
                      "translation":  "(yaitu) bagi siapa di antara kamu yang mau menempuh jalan yang lurus."
                  },
                  {
                      "numberInSurah":  29,
                      "arabic":  "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَٰلَمِينَ",
                      "translation":  "Dan kamu tidak dapat menghendaki (menempuh jalan itu) kecuali apabila dikehendaki Allah, Tuhan semesta alam."
                  }
              ]
}