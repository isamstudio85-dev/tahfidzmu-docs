    "ayahs":  [
                  {
                      "numberInSurah":  1,
                      "arabic":  "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ",
                      "translation":  "Demi langit dan yang datang pada malam hari,"
                  },
                  {
                      "numberInSurah":  2,
                      "arabic":  "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
                      "translation":  "tahukah kamu apakah yang datang pada malam hari itu?"
                  },
                  {
                      "numberInSurah":  3,
                      "arabic":  "ٱلنَّجْمُ ٱلثَّاقِبُ",
                      "translation":  "(yaitu) bintang yang cahayanya menembus,"
